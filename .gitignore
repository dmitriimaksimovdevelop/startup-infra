# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/tfplan
terraform/.terraform.lock.hcl

# Secrets -- NEVER commit these
terraform/terraform.tfvars
terraform/backend.tfvars

# Generated manifests
terraform/.kubeconfig
terraform/.gateway.yaml
terraform/.cluster-issuer.yaml
terraform/.certificate.yaml

# Kubeconfig / Talosconfig
kubeconfig
talosconfig
terraform/talosconfig
*.kubeconfig
*.talosconfig

# Helm dependency build artifacts (regenerated by helm dependency build)
apps/*/.helm/charts/
apps/*/.helm/Chart.lock

# OS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment files
.env
.env.*
